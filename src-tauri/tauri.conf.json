{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Steam Quick Switch",
  "version": "0.1.0",
  "identifier": "com.bxnny24.steamquickswitch",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Steam Quick Switch",
        "width": 380,
        "height": 560,
        "minWidth": 340,
        "minHeight": 420,
        "resizable": true,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
