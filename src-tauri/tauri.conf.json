{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Steam Quick Switch",
  "version": "0.1.0",
  "identifier": "com.bxnny24.steamquickswitch",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Bxnny24/Steam-Quick-Switch/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEEwQzgwMTM5NkExNjA5QUEKUldTcUNSWnFPUUhJb1BsUVlObGpLeXNaNFpvNGx2UDliQTd1OW5LYzBnY3Myb2VnOEFBMG4xRE4K"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
